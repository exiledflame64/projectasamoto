# ---------------------------------------------------------------------------
# Unreal Engine project .gitignore
# Commit: .uproject, Config/, Source/, Content/ (binary Content via Git LFS).
# Ignore: generated build output and editor caches.
# ---------------------------------------------------------------------------

# Engine-generated build output
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/

# Packaged Demos
Packaged/

# Template textures
template_assets/

# Project files generated by GenerateProjectFiles
*.sln
*.suo
*.xcodeproj
*.xcworkspace
.vsconfig

# Visual Studio / Rider / VS Code IDE state
.vs/
.vscode/
.idea/
*.VC.db
*.opendb
*.opensdf
*.sdf
*.suo
*.user
*.userprefs

# Compiled object/precompiled headers
*.obj
*.pch
*.pdb

# OS cruft
Thumbs.db
.DS_Store

# ---------------------------------------------------------------------------
# Project-local planning / handoff docs (not part of the shipped project)
# ---------------------------------------------------------------------------
baoding.md
road_todos.md
todos.md
introduction.md